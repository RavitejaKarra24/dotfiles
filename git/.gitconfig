# This is Git's per-user configuration file.
[user]
	name = RavitejaKarra24
	email = ravitejakarra24@gmail.com

[credential]
	helper = osxkeychain

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[core]
	pager = delta
	editor = nvim

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	last = log -1 HEAD
	lg = log --oneline --graph --decorate -20
	undo = reset --soft HEAD~1
	amend = commit --amend --no-edit
