[
    {
        "context": "Workspace",
        "bindings": {
            // Netrw / project explorer
            "space p v": "project_panel::ToggleFocus",

            // Telescope-ish
            "space p f": "file_finder::Toggle",
            "ctrl-p": "file_finder::Toggle",
            "space p g": ["pane::DeploySearch", { "replace_enabled": false }],
            "space p s": ["pane::DeploySearch", { "replace_enabled": false }],

            // Git / panels
            "space g s": "git_panel::ToggleFocus",
            "space q": "diagnostics::Deploy",

            // Terminal
            "space t t": "terminal_panel::ToggleFocus",
            "space t h": ["workspace::SendKeystrokes", "ctrl-w s ctrl-`"],
            "space t v": ["workspace::SendKeystrokes", "ctrl-w v ctrl-`"],

            // Zed config access
            "space v p p": "zed::OpenSettingsFile",
            "space v p l": "zed::OpenKeymapFile",

            // Save
            "ctrl-s": "workspace::Save",
        },
    },

    {
        "context": "vim_mode == insert && !menu",
        "bindings": {
            // Your Neovim insert escapes
            "j k": "vim::NormalBefore",
            "ctrl-c": "vim::NormalBefore",
            "ctrl-h": "editor::ShowSignatureHelp",
        },
    },

    {
        "context": "VimControl && !menu",
        "bindings": {
            // Your movement/editing muscle memory
            "J": ["workspace::SendKeystrokes", "shift-j"],
            "ctrl-d": "vim::ScrollDown",
            "ctrl-u": "vim::ScrollUp",
            "n": ["workspace::SendKeystrokes", "n z z z v"],
            "shift-n": ["workspace::SendKeystrokes", "shift-n z z z v"],

            // LSP, based on your nvim/lua/plugins/lsp.lua
            "g d": "editor::GoToDefinition",
            "g D": "editor::GoToDeclaration",
            "g i": "editor::GoToImplementation",
            "g r": "editor::FindAllReferences",
            "K": "editor::Hover",
            "space c a": "editor::ToggleCodeActions",
            "space r n": "editor::Rename",
            "space e": "editor::ToggleDiagnostics",
            "g l": "editor::ToggleDiagnostics",
            "[ d": "editor::GoToPreviousDiagnostic",
            "] d": "editor::GoToDiagnostic",

            // Formatting
            "space f": "editor::Format",
            "space c f": "editor::Format",

            // Quickfix/location-list approximations
            "ctrl-k": "editor::GoToDiagnostic",
            "ctrl-j": "editor::GoToPreviousDiagnostic",
            "space k": "editor::GoToDiagnostic",
            "space j": "editor::GoToPreviousDiagnostic",

            // Clipboard/delete approximations
            "space y": "editor::Copy",
            "space Y": ["workspace::SendKeystrokes", "y $"],
            "space d": "editor::Delete",

            // Search/replace word under cursor approximation
            "space s": ["pane::DeploySearch", { "replace_enabled": true }],

            // Undo tree replacement: Zed has native timeline/history, not Undotree
            "space u": "git::FileHistory",

            // Harpoon-ish replacement: Zed has bookmarks, not Harpoon lists
            "space a": "pane::TogglePinTab",
            "ctrl-e": "tab_switcher::Toggle",
            "space 1": ["pane::ActivateItem", 0],
            "space 2": ["pane::ActivateItem", 1],
            "space 3": ["pane::ActivateItem", 2],
            "space 4": ["pane::ActivateItem", 3],
            "ctrl-shift-n": "pane::ActivateNextItem",
            "ctrl-shift-p": "pane::ActivatePreviousItem",

            // Comments/surround are built into Zed Vim mode:
            // gcc, gc, ys, cs, ds
            "Q": "zed::NoAction",
        },
    },

    {
        "context": "vim_mode == visual && !menu",
        "bindings": {
            // Move selected lines
            "J": "editor::MoveLineDown",
            "K": "editor::MoveLineUp",

            // Clipboard
            "space y": "editor::Copy",
            "y": "editor::Copy",

            // Paste over selection. Exact black-hole-register behavior is not available.
            "space p": "editor::Paste",

            // Visual surround support
            "s": "vim::PushSneak",
            "shift-s": "vim::PushSneakBackward",
            "shift-x": "vim::Exchange",
        },
    },

    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            // Netrw-style project panel navigation
            "h": "project_panel::CollapseSelectedEntry",
            "l": "project_panel::ExpandSelectedEntry",
            "o": "project_panel::Open",
            "enter": "project_panel::Open",
            "t": "project_panel::OpenPermanent",
            "v": "project_panel::OpenSplitVertical",
            "s": "project_panel::OpenSplitHorizontal",
            "a": "project_panel::NewFile",
            "A": "project_panel::NewDirectory",
            "r": "project_panel::Rename",
            "d": "project_panel::Trash",
        },
    },

    {
        "context": "Dock",
        "bindings": {
            // tmux/vim-style pane movement
            "ctrl-w h": "workspace::ActivatePaneLeft",
            "ctrl-w j": "workspace::ActivatePaneDown",
            "ctrl-w k": "workspace::ActivatePaneUp",
            "ctrl-w l": "workspace::ActivatePaneRight",
        },
    },
]
